# Godot 4
.godot/
export.cfg
export_presets.cfg
*.translation
*.mono/
data_*/
# arc-4 iter 130: ignore auto-generated .uid files (Godot 4 makes
# one per .gd/.tres on first load). 27 already-tracked .uid files
# stay tracked (UID references in scene files); new ones (~45 at
# iter 130) no longer clutter `git status`.
*.uid

# Godot 3 legacy (kept for history)
.import/
*.import

# macOS
.DS_Store

# Loop output
tools/out/

# Arc-5/arc-v0.2 bot-harness: generated per-run telemetry (regenerable via
# make check-84-runs / bot-harness / the arc runner). The seed bank + fixtures
# ARE source. Recursive so the arc subdir (data/telemetry/arc/) is covered too.
data/telemetry/**/*.json
data/telemetry/*.json

